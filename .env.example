# ============================================================
# ACTUALYZA PROSPECTING SYSTEM — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env a git.
# ============================================================

# ─────────────────────────────────────────────────────────────
# GOOGLE PLACES API
# Para qué : encontrar clínicas por categoría y ubicación
# Etapa    : 1 — base de todo el sistema de datos
# Obtener  : https://console.cloud.google.com/apis/credentials
# Activar  : "Places API (New)" en tu proyecto de Google Cloud
# Costo    : ~$17 por 1,000 búsquedas (primeros $200/mes gratis)
# ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ─────────────────────────────────────────────────────────────
# META AD LIBRARY
# Para qué : contar anuncios activos por página (proxy de inversión)
# Etapa    : 2 — filtro central del sistema
# Cómo     : developers.facebook.com/apps → Create App → Basic Settings
# Token    : se construye como APP_ID|APP_SECRET (no requiere aprobación)
# ─────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ─────────────────────────────────────────────────────────────
# NOTION
# Para qué : base de datos de prospectos y dashboard
# Etapa    : todas — el sistema crea la página y DB automáticamente
# Obtener  : https://www.notion.so/my-integrations → New integration
# Nota     : deja NOTION_DATABASE_ID vacío; el sistema lo genera y lo guarda
# ─────────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ─────────────────────────────────────────────────────────────
# EMAIL — Hostinger SMTP
# Para qué : envío de correos de prospección por etapas
# Etapa    : 5 — módulo de outreach
# Host     : smtp.hostinger.com  |  Puerto: 587 (TLS)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=Actualyza

# ─────────────────────────────────────────────────────────────
# HUNTER.IO (opcional — encontrar emails de contacto por dominio)
# Para qué : buscar correo del dueño/manager por dominio web
# Etapa    : 2 — enriquecimiento (complementa Sunbiz)
# Obtener  : https://hunter.io/api-keys  (plan gratis: 25 búsquedas/mes)
# ─────────────────────────────────────────────────────────────
HUNTER_API_KEY=

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DEL PIPELINE
# ─────────────────────────────────────────────────────────────
SUNBIZ_REQUEST_DELAY=3
MAX_CLINICS_PER_RUN=20
TARGET_CITY=Miami
TARGET_STATE=FL

# ── LÍMITES MENSUALES DE API ──────────────────────────────────
# Google Places: $200 crédito/mes = 6,250 requests gratuitos (~$17/1,000)
# 3,750 = 60% del límite gratuito — margen del 40% libre (≈$63.75 máx, cubierto por crédito)
GOOGLE_PLACES_MONTHLY_LIMIT=3750
SUNBIZ_MONTHLY_LIMIT=500
META_SCRAPING_MONTHLY_LIMIT=300
