{
  "name": "Facebook Comments → Actualyza CRM",
  "flow": [
    {
      "id": 1,
      "module": "facebook-pages:TriggerWatchPostComments",
      "version": 1,
      "parameters": {
        "pageId": null
      },
      "mappings": [],
      "metadata": {
        "designer": { "x": 0, "y": 0 },
        "parameters": [
          { "name": "pageId", "type": "select", "label": "Facebook Page" }
        ]
      }
    },
    {
      "id": 2,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": {
        "handleErrors": false,
        "useNewZLibDeCompress": true
      },
      "mappings": {
        "url": "https://actualyza-prospecting-production.up.railway.app/webhook/social-comment",
        "method": "post",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "bodyType": "raw",
        "contentType": "application/json",
        "parseResponse": true,
        "rejectUnauthorized": true,
        "followRedirect": true,
        "gzip": true,
        "body": "{\"username\":\"{{1.from.id}}\",\"full_name\":\"{{1.from.name}}\",\"comment_text\":\"{{1.message}}\",\"post_id\":\"{{1.id}}\",\"source\":\"facebook_comment\"}"
      },
      "metadata": {
        "designer": { "x": 300, "y": 0 }
      }
    }
  ],
  "metadata": {
    "instant": false,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": { "orphans": [] }
  }
}
